@page
@model IndexModel
@{
    ViewData["Title"] = "MeetingHub 測試";
}

<div class="form-group">
    &nbsp;
</div>

<div id="entrance">
    <label for="token">Token:</label>
    <input type="text" id="token" style="width: 1200px;"/>
    <button onclick="sendMethod()">繼續</button>
</div>

<div id="divToken" style="display: none;">
    Token:
    <h6 id="spn-token"></h6>
    <form id="frm-send-message" action="#">
        <label for="method">方法:</label>
        <input type="text" id="method"/>
        <br/>
        <label for="message">Message:</label>
        <textarea rows="6" cols="180" id="message" ></textarea>
        <input type="submit" id="send" value="呼叫方法" class="send"/>
    </form>
    <div class="clear">
    </div>
    <ul id="messages"></ul>
</div>

<script src="lib/signalr/signalr.min.js"></script>

<script>
    var connection;
    function sendMethod() {
        var token = $('#token').val();
        $('#spn-token').text(token);
        $('#entrance').hide();
        $('#divToken').show();
        connection = new signalR.HubConnectionBuilder()
            .withUrl("https://airreferral.datacom.com.tw/MeetingHub")
            .build();

        connection.start().catch(err => {
            console.error(err.toString());
        });
    }

    document.getElementById('frm-send-message').addEventListener('submit', event => {
        let message = $('#message').val();
        let method = $('#method').val();

        var postData;
        if(message.startsWith("{"))
            postData = JSON.parse(message);
        else
            postData = eval(message);
        connection.invoke(method, postData).then(e => {
            if(e.success)
                appendLine("↑:"+method+", ↓:成功, data:"+JSON.stringify(e.data));
            else
                appendLine("↑:"+method+", ↓:"+e.message);
        });
        
        event.preventDefault();
    });

    function appendLine(message) {  
        let msgElement = document.createElement('em');
        msgElement.innerText = ` ${message}`;

        let li = document.createElement('li');
        li.appendChild(msgElement);
       
        $('#messages').append(li);
    };

</script>